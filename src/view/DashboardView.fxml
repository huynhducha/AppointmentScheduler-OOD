<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.DashboardController">

    <top>
        <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="HỆ THỐNG QUẢN LÝ LỊCH TRÌNH - ĐỒ ÁN PBL"
               BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets bottom="20.0" top="20.0"/>
            </BorderPane.margin>
        </Label>
    </top>

    <center>
        <TableView fx:id="tblAppointments" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
            <columns>
                <TableColumn fx:id="colId" prefWidth="80.0" text="ID"/>
                <TableColumn fx:id="colTitle" prefWidth="250.0" text="Tiêu đề"/>
                <TableColumn fx:id="colLocation" prefWidth="200.0" text="Địa điểm"/>
                <TableColumn fx:id="colStart" prefWidth="170.0" text="Bắt đầu"/>
                <TableColumn fx:id="colEnd" prefWidth="170.0" text="Kết thúc"/>
            </columns>
            <BorderPane.margin>
                <Insets left="20.0" right="20.0"/>
            </BorderPane.margin>
        </TableView>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" prefHeight="80.0" spacing="15.0" BorderPane.alignment="CENTER">
            <children>
                <Button fx:id="btnRefresh" mnemonicParsing="false" onAction="#handleRefresh" prefHeight="35.0"
                        prefWidth="100.0" text="Làm mới"/>
                <Button fx:id="btnAddApp" mnemonicParsing="false" onAction="#showAddDialog" prefHeight="35.0"
                        prefWidth="130.0"
                        style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold;"
                        text="+ Thêm lịch hẹn"/>
            </children>
            <BorderPane.margin>
                <Insets right="20.0"/>
            </BorderPane.margin>
        </HBox>
    </bottom>
</BorderPane>
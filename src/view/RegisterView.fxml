<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="350.0" prefWidth="400.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.RegisterController">
    <children>
        <Label layoutX="113.0" layoutY="30.0" text="ĐĂNG KÝ TÀI KHOẢN" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="18.0"/>
            </font>
        </Label>

        <Label layoutX="50.0" layoutY="80.0" text="Họ và Tên:"/>
        <TextField fx:id="txtFullName" layoutX="50.0" layoutY="100.0" prefHeight="35.0" prefWidth="300.0"
                   promptText="VD: Huỳnh Đức Hà"/>

        <Label layoutX="50.0" layoutY="150.0" text="Email:"/>
        <TextField fx:id="txtEmail" layoutX="50.0" layoutY="170.0" prefHeight="35.0" prefWidth="300.0"
                   promptText="VD: ha@gmail.com"/>

        <Button layoutX="50.0" layoutY="230.0" mnemonicParsing="false" onAction="#onRegisterClick" prefHeight="40.0"
                prefWidth="300.0" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;"
                text="XÁC NHẬN ĐĂNG KÝ"/>

        <Button layoutX="145.0" layoutY="290.0" mnemonicParsing="false" onAction="#onBackToLoginClick"
                style="-fx-background-color: transparent; -fx-text-fill: #3498db; -fx-cursor: hand;"
                text="Quay lại Đăng nhập" underline="true"/>
    </children>
</AnchorPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane prefHeight="500.0" prefWidth="850.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.AppointmentListController">

    <top>
        <Label style="-fx-font-size: 22px; -fx-font-weight: bold;" text="Danh sách các buổi hẹn"
               BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets bottom="15.0" top="20.0"/>
            </BorderPane.margin>
        </Label>
    </top>

    <center>
        <TableView fx:id="tblAppointments" prefHeight="350.0" prefWidth="800.0" BorderPane.alignment="CENTER">
            <columns>
                <TableColumn fx:id="colId" prefWidth="60.0" text="ID"/>
                <TableColumn fx:id="colTitle" prefWidth="220.0" text="Tên sự kiện"/>
                <TableColumn fx:id="colLocation" prefWidth="180.0" text="Vị trí"/>
                <TableColumn fx:id="colDate" prefWidth="120.0" text="Ngày diễn ra"/>
                <TableColumn fx:id="colStart" prefWidth="100.0" text="Giờ bắt đầu"/>
                <TableColumn fx:id="colEnd" prefWidth="100.0" text="Giờ kết thúc"/>
            </columns>
            <BorderPane.margin>
                <Insets left="20.0" right="20.0"/>
            </BorderPane.margin>
        </TableView>
    </center>

    <bottom>
        <HBox alignment="CENTER" prefHeight="70.0" spacing="20.0" BorderPane.alignment="CENTER">
            <children>
                <Button mnemonicParsing="false" onAction="#onRefresh" prefHeight="35.0" prefWidth="100.0"
                        style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;"
                        text="Làm mới"/>

                <Button mnemonicParsing="false" onAction="#onEdit" prefHeight="35.0" prefWidth="100.0"
                        style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold;"
                        text="Sửa"/>

                <Button mnemonicParsing="false" onAction="#onDelete" prefHeight="35.0" prefWidth="100.0"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;" text="Xóa"/>
                <Button mnemonicParsing="false" onAction="#onClose" prefHeight="35.0" prefWidth="100.0" text="Đóng"/>
            </children>
        </HBox>
    </bottom>
</BorderPane>